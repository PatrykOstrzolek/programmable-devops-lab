server {
    listen 80;
    server_name {{ web_domain_name }};
    root {{ web_document_root }};
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:{{ php_fpm_socket }};
    }

    location ~ /\.ht {
        deny all;
    }
}